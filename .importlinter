[importlinter]
root_packages =
    common
    ocr
    sensor
    serial_input
    sheets
    storage
    timer
    ui

# 想定する依存方向（上ほど上位/具体的、下ほど基盤的）：
#   main(エントリーポイント、全てを参照可)
#     -> ui    (画面)
#     -> sheets(Googleスプレッドシート連携)
#     -> storage(ローカル保存。timerには依存してよい)
#     -> ocr   (OCRゼッケン認識。完全に独立)
#     -> sensor(センサー。完全に独立)
#     -> timer (計時ロジック。完全に独立)
# ocr/sensor/timerは最も基盤的な層で、互いにも他層にも依存しない。
# storageはtimerにのみ依存してよいが、sheets/ui/sensor/ocrをimportしてはならない（依存の逆転を禁止）。

[importlinter:contract:storage-no-upward]
name = storageはsheets/ui/sensor/ocrに依存してはならない（timerへの依存は許可）
type = forbidden
source_modules =
    storage
forbidden_modules =
    sheets
    ui
    sensor
    ocr

[importlinter:contract:sensor-independent]
name = sensorはsheets/storage/ui/timer/ocrに依存してはならない（完全に独立した層）
type = forbidden
source_modules =
    sensor
forbidden_modules =
    sheets
    storage
    ui
    timer
    ocr

[importlinter:contract:ocr-independent]
name = ocrはsheets/storage/ui/timer/sensorに依存してはならない（完全に独立した層）
type = forbidden
source_modules =
    ocr
forbidden_modules =
    sheets
    storage
    ui
    timer
    sensor

[importlinter:contract:serial-input-independent]
name = serial_inputはsheets/storage/ui/timer/sensor/ocrに依存してはならない（完全に独立した層）
type = forbidden
source_modules =
    serial_input
forbidden_modules =
    sheets
    storage
    ui
    timer
    sensor
    ocr

[importlinter:contract:timer-independent]
name = timerはsheets/storage/ui/sensor/ocrに依存してはならない（完全に独立した層）
type = forbidden
source_modules =
    timer
forbidden_modules =
    sheets
    storage
    ui
    sensor
    ocr

[importlinter:contract:sheets-no-ui]
name = sheets（ビジネスロジック層）はui（Tkinter画面層）に依存してはならない
type = forbidden
source_modules =
    sheets
forbidden_modules =
    ui

[importlinter:contract:ui-no-sheets]
name = ui（画面層）はsheets（Googleスプレッドシート連携層）に依存してはならない
type = forbidden
source_modules =
    ui
forbidden_modules =
    sheets

[importlinter:contract:common-is-pure]
name = common（共通層・ハブ）は他のどの層にも依存してはならない（依存される側専用）
type = forbidden
source_modules =
    common
forbidden_modules =
    sheets
    storage
    ui
    sensor
    timer
    ocr
    serial_input
